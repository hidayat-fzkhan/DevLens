# Azure DevOps (TFS)
ADO_ORG=my-org
ADO_PROJECT=my-project
ADO_PAT=xxxxxxxxxxxxxxxxxxxx

# GitHub
# Repositories are managed in the UI (Home page → Repo Manager) and persisted
# to backend/data/repos.json. Only the token is read from env.
# Optional but recommended for private repos and higher rate limits.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional defaults
ADO_DAYS=7
ADO_TOP=10
ADO_STATES=New,Active
ADO_AREA_PATH=Consumer Solutions\\Integrated Front Office BU\\Knock Program\\Knock Claw
GITHUB_COMMITS=50

# API server
API_PORT=4000

# Anthropic AI
ANTHROPIC_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
